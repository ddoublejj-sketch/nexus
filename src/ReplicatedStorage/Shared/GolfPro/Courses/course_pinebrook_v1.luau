local Constants = require("../Constants")

local function zone(
	id: string,
	surface: string,
	priority: number,
	minX: number,
	maxX: number,
	minY: number,
	maxY: number
)
	return {
		id = id,
		surface = surface,
		priority = priority,
		bounds = {
			minX = minX,
			maxX = maxX,
			minY = minY,
			maxY = maxY,
		},
	}
end

