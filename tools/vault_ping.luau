--!strict

local fs = require("@lune/fs")
local net = require("@lune/net")
local process = require("@lune/process")

local SECRET_PATH = "secrets/obsidian.env"
local VAULT_ROOT = "C:/Users/jackw/Roblox/RobloxGameVault"
local PING_NOTE_PATH = "90_Automation/Generated/Ping.md"
local LOG_ROOT = VAULT_ROOT .. "/90_Automation/Logs"
local PENDING_ROOT = LOG_ROOT .. "/pending"
local SENT_ROOT = LOG_ROOT .. "/sent"

type RestConfig = {
	apiUrl: string,
	apiKey: string,
}

local function trim(value: string): string
	return value:match("^%s*(.-)%s*$") or ""
end

local function readEnvFile(path: string): { [string]: string }
	local values = {}

	if not fs.isFile(path) then
		return values
	end

	for line in fs.readFile(path):gmatch("[^\r\n]+") do
		local stripped = trim(line)
		if stripped ~= "" and not stripped:match("^#") then
			local key, value = stripped:match("^([%w_]+)%s*=%s*(.+)$")
			if key and value then
				values[key] = trim(value)
			end
		end
	end

	return values
end

local function readConfig(): RestConfig?
	local fileValues = readEnvFile(SECRET_PATH)
	local apiUrl = process.env.OBSIDIAN_API_URL or fileValues.OBSIDIAN_API_URL
	local apiKey = process.env.OBSIDIAN_API_KEY or fileValues.OBSIDIAN_API_KEY

	if apiUrl == nil or apiUrl == "" or apiKey == nil or apiKey == "" then
		return nil
	end

	return {
		apiUrl = apiUrl:gsub("/+$", ""),
		apiKey = apiKey,
	}
end

local function encodeVaultPath(path: string): string
	local segments = {}

	for segment in path:gmatch("[^/]+") do
		table.insert(segments, net.urlEncode(segment))
	end

	return table.concat(segments, "/")
end

local function isoTimestamp(): string
	return os.date("!%Y-%m-%dT%H:%M:%SZ")
end

local function fileTimestamp(): string
	return os.date("!%Y%m%dT%H%M%SZ")
end

local function ensureDir(path: string)
	if not fs.isDir(path) then
		fs.writeDir(path)
	end
end

local function sanitizePath(value: string): string
	return value:gsub("[^%w%.%-_]+", "_")
end

local function pendingEnvelope(
	targetPath: string,
	body: string,
	reason: string,
	timestamp: string
): string
	return table.concat({
		"target_path: " .. targetPath,
		"queued_at: " .. timestamp,
		"reason: " .. reason:gsub("[\r\n]+", " "),
		"---",
		body,
	}, "\n")
end

local function parsePendingEnvelope(contents: string): (string?, string?)
	local header, body = contents:match("^(.-)\n%-%-%-\n(.*)$")
	if not header or not body then
		return nil, nil
	end

	local targetPath = header:match("\ntarget_path:%s*([^\r\n]+)")
		or header:match("^target_path:%s*([^\r\n]+)")
	return if targetPath then trim(targetPath) else nil, body
end

local function queueWrite(targetPath: string, body: string, reason: string, timestamp: string)
	ensureDir(LOG_ROOT)
	ensureDir(PENDING_ROOT)
	local path = ("%s/%s_%s.pending"):format(
		PENDING_ROOT,
		fileTimestamp(),
		sanitizePath(targetPath)
	)
	fs.writeFile(path, pendingEnvelope(targetPath, body, reason, timestamp))
	print(("Queued pending vault write: %s"):format(path))
	print("This is not G3 acceptance; it will flush after Obsidian REST is configured.")
end

local function writeViaRest(
	config: RestConfig,
	targetPath: string,
	body: string
): (boolean, string?)
	local response = net.request({
		url = config.apiUrl .. "/vault/" .. encodeVaultPath(targetPath),
		method = "PUT",
		headers = {
			Authorization = "Bearer " .. config.apiKey,
			["Content-Type"] = "text/plain",
		},
		body = body,
	})

	if not response.ok then
		return false,
			("Failed to write %s via Obsidian REST: %d %s\n%s"):format(
				targetPath,
				response.statusCode,
				response.statusMessage,
				response.body
			)
	end

	return true, nil
end

local function flushPending(config: RestConfig): number
	if not fs.isDir(PENDING_ROOT) then
		return 0
	end

	ensureDir(LOG_ROOT)
	ensureDir(SENT_ROOT)
	local flushed = 0

	for _, entry in fs.readDir(PENDING_ROOT) do
		if entry:match("%.pending$") then
			local pendingPath = PENDING_ROOT .. "/" .. entry
			local sentPath = SENT_ROOT .. "/" .. entry:gsub("%.pending$", ".sent")
			if fs.isFile(sentPath) then
				continue
			end

			local envelope = fs.readFile(pendingPath)
			local targetPath, body = parsePendingEnvelope(envelope)

			if targetPath and body then
				local ok, err = writeViaRest(config, targetPath, body)
				if not ok then
					error(err)
				end

				fs.writeFile(sentPath, envelope)
				flushed += 1
			end
		end
	end

	return flushed
end

local function buildPingNote(timestamp: string): string
	return table.concat({
		"---",
		"type: system",
		"status: active",
		"owner:",
		"source_path: C:\\Users\\jackw\\Roblox\\nexus\\tools\\vault_ping.luau",
		"roblox_asset_id:",
		"studio_instance_path:",
		"dependencies:",
		"last_synced: " .. timestamp,
		"tags:",
		"---",
		"",
		"# Ping",
		"",
		"Last ping: " .. timestamp,
		"",
		"Generated by `tools/vault_ping.luau`.",
		"",
	}, "\n")
end

if not fs.isDir(VAULT_ROOT) then
	error("Missing vault directory: " .. VAULT_ROOT)
end

local timestamp = isoTimestamp()
local noteBody = buildPingNote(timestamp)
local config = readConfig()

if not config then
	queueWrite(PING_NOTE_PATH, noteBody, "Missing Obsidian REST config", timestamp)
	process.exit(0)
end

local ok, err = writeViaRest(config, PING_NOTE_PATH, noteBody)
if not ok then
	queueWrite(PING_NOTE_PATH, noteBody, err or "Obsidian REST write failed", timestamp)
	process.exit(0)
end

local flushed = flushPending(config)
print(("Updated %s at %s"):format(PING_NOTE_PATH, timestamp))
print(("Flushed %d pending vault writes"):format(flushed))
