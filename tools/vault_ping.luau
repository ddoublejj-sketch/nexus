--!strict

local fs = require("@lune/fs")
local net = require("@lune/net")
local process = require("@lune/process")

local SECRET_PATH = "secrets/obsidian.env"
local PING_NOTE_PATH = "90_Automation/Generated/Ping.md"

local function trim(value: string): string
	return value:match("^%s*(.-)%s*$") or ""
end

local function readEnvFile(path: string): { [string]: string }
	local values = {}

	if not fs.isFile(path) then
		return values
	end

	for line in fs.readFile(path):gmatch("[^\r\n]+") do
		local stripped = trim(line)
		if stripped ~= "" and not stripped:match("^#") then
			local key, value = stripped:match("^([%w_]+)%s*=%s*(.+)$")
			if key and value then
				values[key] = trim(value)
			end
		end
	end

	return values
end

local function readConfig(): (string, string)
	local fileValues = readEnvFile(SECRET_PATH)
	local apiUrl = process.env.OBSIDIAN_API_URL or fileValues.OBSIDIAN_API_URL
	local apiKey = process.env.OBSIDIAN_API_KEY or fileValues.OBSIDIAN_API_KEY

	if apiUrl == nil or apiUrl == "" or apiKey == nil or apiKey == "" then
		error(
			"Missing Obsidian REST config. Create secrets/obsidian.env with OBSIDIAN_API_URL and OBSIDIAN_API_KEY."
		)
	end

	return apiUrl:gsub("/+$", ""), apiKey
end

local function encodeVaultPath(path: string): string
	local segments = {}

	for segment in path:gmatch("[^/]+") do
		table.insert(segments, net.urlEncode(segment))
	end

	return table.concat(segments, "/")
end

local function isoTimestamp(): string
	return os.date("!%Y-%m-%dT%H:%M:%SZ")
end

local apiUrl, apiKey = readConfig()
local timestamp = isoTimestamp()
local noteBody = table.concat({
	"---",
	"type: system",
	"status: active",
	"owner:",
	"source_path: C:\\Users\\jackw\\Roblox\\nexus\\tools\\vault_ping.luau",
	"roblox_asset_id:",
	"studio_instance_path:",
	"dependencies:",
	"last_synced: " .. timestamp,
	"tags:",
	"---",
	"",
	"# Ping",
	"",
	"Last ping: " .. timestamp,
	"",
	"Generated by `tools/vault_ping.luau`.",
	"",
}, "\n")

local response = net.request({
	url = apiUrl .. "/vault/" .. encodeVaultPath(PING_NOTE_PATH),
	method = "PUT",
	headers = {
		Authorization = "Bearer " .. apiKey,
		["Content-Type"] = "text/plain",
	},
	body = noteBody,
})

if not response.ok then
	error(
		("Failed to write %s via Obsidian REST: %d %s\n%s"):format(
			PING_NOTE_PATH,
			response.statusCode,
			response.statusMessage,
			response.body
		)
	)
end

print(("Updated %s at %s"):format(PING_NOTE_PATH, timestamp))
