--!strict

local fs = require("@lune/fs")
local net = require("@lune/net")
local process = require("@lune/process")
local serde = require("@lune/serde")

local VAULT_ROOT = "C:/Users/jackw/Roblox/RobloxGameVault"
local PLUGIN_DATA_PATH = VAULT_ROOT .. "/.obsidian/plugins/obsidian-local-rest-api/data.json"
local OUTPUT_PATH = VAULT_ROOT .. "/00_Command_Center/Obsidian REST Bootstrap.md"
local SECRET_PATH = "secrets/obsidian.env"
local DEFAULT_SECURE_PORT = 27124
local DEFAULT_INSECURE_PORT = 27123

type PluginSettings = {
	apiKey: string?,
	port: number?,
	insecurePort: number?,
	enableSecureServer: boolean?,
	enableInsecureServer: boolean?,
}

local function isoTimestamp(): string
	return os.date("!%Y-%m-%dT%H:%M:%SZ")
end

local function ensureDir(path: string)
	if not fs.isDir(path) then
		fs.writeDir(path)
	end
end

local function oneLine(value: string): string
	local normalized = value:gsub("\r", "\n"):gsub("\n+", " "):gsub("|", "\\|")
	normalized = normalized:match("^%s*(.-)%s*$") or ""
	if #normalized > 140 then
		return normalized:sub(1, 137) .. "..."
	end

	return normalized
end

local function readPluginSettings(): PluginSettings?
	if not fs.isFile(PLUGIN_DATA_PATH) then
		return nil
	end

	local ok, decoded = pcall(function()
		return serde.decode("json", fs.readFile(PLUGIN_DATA_PATH))
	end)

	if not ok or type(decoded) ~= "table" then
		error("Local REST plugin settings exist but are not valid JSON: " .. PLUGIN_DATA_PATH)
	end

	return decoded :: PluginSettings
end

local function portOr(value: number?, fallback: number): number
	if type(value) == "number" and value > 0 then
		return value
	end

	return fallback
end

local function apiUrlFor(settings: PluginSettings): string
	if settings.enableSecureServer ~= false then
		return ("https://127.0.0.1:%d"):format(portOr(settings.port, DEFAULT_SECURE_PORT))
	end

	if settings.enableInsecureServer == true then
		return ("http://127.0.0.1:%d"):format(portOr(settings.insecurePort, DEFAULT_INSECURE_PORT))
	end

	return ("https://127.0.0.1:%d"):format(portOr(settings.port, DEFAULT_SECURE_PORT))
end

local function writeEnv(apiUrl: string, apiKey: string)
	ensureDir("secrets")
	fs.writeFile(
		SECRET_PATH,
		table.concat({
			"# Generated by tools/obsidian_rest_bootstrap.luau.",
			"# Local machine only; do not commit this file.",
			"OBSIDIAN_API_URL=" .. apiUrl,
			"OBSIDIAN_API_KEY=" .. apiKey,
			"",
		}, "\n")
	)
end

local function restProbe(apiUrl: string, apiKey: string): (boolean, string)
	local ok, response = pcall(function()
		return net.request({
			url = apiUrl .. "/",
			method = "GET",
			headers = {
				Authorization = "Bearer " .. apiKey,
			},
		})
	end)

	if not ok then
		local curlResult = process.exec("curl.exe", {
			"-k",
			"-s",
			"-o",
			"NUL",
			"-w",
			"%{http_code}",
			"-H",
			"Authorization: Bearer " .. apiKey,
			apiUrl .. "/",
		})

		if curlResult.ok and curlResult.stdout:match("^2%d%d") then
			return true, "root route responded via local curl fallback"
		end

		return false, oneLine(tostring(response))
	end

	local restResponse = response :: any
	if not restResponse.ok then
		return false, ("%d %s"):format(restResponse.statusCode, oneLine(restResponse.statusMessage))
	end

	return true, "root route responded"
end

local function writeEvidence(
	timestamp: string,
	settingsState: string,
	secretState: string,
	restState: string,
	nextAction: string
)
	local lines = {
		"---",
		"type: system",
		"status: active",
		"owner:",
		"source_path: C:\\Users\\jackw\\Roblox\\nexus\\tools\\obsidian_rest_bootstrap.luau",
		"roblox_asset_id:",
		"studio_instance_path:",
		"dependencies:",
		"last_synced: " .. timestamp,
		"tags: gates, g3, obsidian",
		"---",
		"",
		"# Obsidian REST Bootstrap",
		"",
		"Generated: " .. timestamp,
		"",
		"This note records only non-secret REST setup state. The API key is written only to `secrets/obsidian.env` and is never printed here.",
		"",
		"| Item | State | Detail |",
		"| --- | --- | --- |",
		"| Local REST plugin settings | " .. settingsState .. " | " .. PLUGIN_DATA_PATH .. " |",
		"| Nexus REST secret file | " .. secretState .. " | " .. SECRET_PATH .. " values hidden |",
		"| Live REST probe | "
			.. restState
			.. " | `GET /` with bearer auth, response body omitted |",
		"",
		"## Next Action",
		"",
		nextAction,
		"",
		"After this reports a live REST response, run `lune run tools/vault_ping.luau` to flush pending writes, then run `./nexus.ps1 gatecheck --gate G3`.",
	}

	fs.writeFile(OUTPUT_PATH, table.concat(lines, "\n") .. "\n")
end

if not fs.isDir(VAULT_ROOT) then
	error("Missing vault directory: " .. VAULT_ROOT)
end

local timestamp = isoTimestamp()
local settings = readPluginSettings()

if not settings then
	local nextAction = table.concat({
		"- Open `C:\\Users\\jackw\\Roblox\\RobloxGameVault` in Obsidian as a vault.",
		"- Trust the vault if Obsidian asks, and make sure community plugins are enabled.",
		"- Confirm `Local REST API with MCP` is enabled, then reopen its settings once so it writes `data.json`.",
		"- Re-run `./nexus.ps1 obsidian-rest`.",
	}, "\n")
	writeEvidence(timestamp, "WAITING", "NOT WRITTEN", "NOT CHECKED", nextAction)
	print("Obsidian Local REST settings are not generated yet.")
	print(
		"Open the vault in Obsidian, enable/trust plugins, then run ./nexus.ps1 obsidian-rest again."
	)
	print("Wrote Obsidian REST bootstrap evidence to " .. OUTPUT_PATH)
	process.exit(0)
end

if type(settings.apiKey) ~= "string" or settings.apiKey == "" then
	error(
		"Local REST plugin settings exist but do not include an API key yet: " .. PLUGIN_DATA_PATH
	)
end

local apiUrl = apiUrlFor(settings)
writeEnv(apiUrl, settings.apiKey)

local restOk, restDetail = restProbe(apiUrl, settings.apiKey)
local nextAction = if restOk
	then "- REST responded. Run `lune run tools/vault_ping.luau`, then verify G3."
	else "- REST secret file is ready, but Obsidian is not reachable yet. Open the vault in Obsidian and re-run this command."

writeEvidence(
	timestamp,
	"FOUND",
	"WRITTEN",
	if restOk then "PASS" else "WAITING: " .. restDetail,
	nextAction
)

print("Wrote secrets/obsidian.env from Obsidian plugin settings (key hidden).")
print("REST probe: " .. (if restOk then "PASS" else "WAITING - " .. restDetail))
print("Wrote Obsidian REST bootstrap evidence to " .. OUTPUT_PATH)
